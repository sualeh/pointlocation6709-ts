{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES6",
    "declaration": true,
    "allowJs": false,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "removeComments": false,
    "alwaysStrict": true,
    "noImplicitAny": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "rootDir": "src/main/typescript",
    "outDir": "dist",
    "declarationDir": "dist",
    "listEmittedFiles": true,
    "pretty": true
  },
  "include": [
    "src/main/typescript/**/*"
  ],
  "exclude": [
    "src/main/typescript/**/*main*"
  ]
}